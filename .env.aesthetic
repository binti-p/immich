# ============================================================================
# Immich Aesthetic Integration - Environment Configuration
# ============================================================================
# Copy this file to .env and update the values as needed
# ============================================================================

# ----------------------------------------------------------------------------
# Immich Database Configuration
# ----------------------------------------------------------------------------
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=./postgres-data

# ----------------------------------------------------------------------------
# Data Pipeline Database Configuration
# ----------------------------------------------------------------------------
DATA_PIPELINE_DB_NAME=aesthetic_hub
DATA_PIPELINE_POSTGRES_USER=aesthetic
DATA_PIPELINE_POSTGRES_PASSWORD=aesthetic_password
DATA_PIPELINE_DB_USER=immich_readonly
DATA_PIPELINE_DB_PASSWORD=readonly_password
DATA_PIPELINE_DB_DATA_LOCATION=./data-pipeline-postgres-data

# ----------------------------------------------------------------------------
# Upload Storage Configuration
# ----------------------------------------------------------------------------
UPLOAD_LOCATION=./uploads

# ----------------------------------------------------------------------------
# Aesthetic Scoring Configuration
# ----------------------------------------------------------------------------
ENABLE_AESTHETIC_SCORING=true
TRITON_URL=http://triton:8000

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
IMMICH_LOG_LEVEL=log
IMMICH_LOG_FORMAT=json
SCORING_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Monitoring Configuration (Optional)
# ----------------------------------------------------------------------------
GRAFANA_PASSWORD=admin

# ----------------------------------------------------------------------------
# Immich Version (Optional)
# ----------------------------------------------------------------------------
# IMMICH_VERSION=release

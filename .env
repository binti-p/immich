# ============================================================================
# Immich Aesthetic Integration - Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Immich Database Configuration
# ----------------------------------------------------------------------------
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=./postgres-data

# ----------------------------------------------------------------------------
# Upload Storage Configuration
# ----------------------------------------------------------------------------
UPLOAD_LOCATION=./uploads

# ----------------------------------------------------------------------------
# Aesthetic Scoring Configuration
# ----------------------------------------------------------------------------
ENABLE_AESTHETIC_SCORING=true
TRITON_URL=http://triton:8000

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
IMMICH_LOG_LEVEL=log
IMMICH_LOG_FORMAT=json
SCORING_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Monitoring Configuration (Optional)
# ----------------------------------------------------------------------------
GRAFANA_PASSWORD=admin

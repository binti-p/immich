{
  "title": "Immich Aesthetic Integration",
  "uid": "immich-aesthetic-integration",
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Upload Rate (uploads/minute)",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(immich_upload_events_total_success[5m])) * 60",
          "legendFormat": "Successful Uploads",
          "refId": "A"
        },
        {
          "expr": "sum(rate(immich_upload_events_total_failure[5m])) * 60",
          "legendFormat": "Failed Uploads",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Uploads per minute"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "pointradius": 5,
      "legend": {
        "show": true,
        "values": true,
        "current": true,
        "alignAsTable": true
      }
    },
    {
      "id": 2,
      "title": "Feature Service Latency (p50, p95, p99)",
      "type": "graph",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(immich_feature_service_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(immich_feature_service_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(immich_feature_service_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "ms",
          "label": "Latency (milliseconds)"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "lines": true,
      "fill": 0,
      "linewidth": 2,
      "pointradius": 5,
      "legend": {
        "show": true,
        "values": true,
        "current": true,
        "alignAsTable": true
      }
    },
    {
      "id": 3,
      "title": "Gallery Query Rate",
      "type": "graph",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(immich_gallery_queries_total_has_scores_true[5m]))",
          "legendFormat": "Queries with scores",
          "refId": "A"
        },
        {
          "expr": "sum(rate(immich_gallery_queries_total_has_scores_false[5m]))",
          "legendFormat": "Queries without scores",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "reqps",
          "label": "Queries per second"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "pointradius": 5,
      "legend": {
        "show": true,
        "values": true,
        "current": true,
        "alignAsTable": true
      }
    },
    {
      "id": 4,
      "title": "Gallery Score Availability Rate",
      "type": "graph",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(immich_gallery_queries_total_has_scores_true[5m])) / (sum(rate(immich_gallery_queries_total_has_scores_true[5m])) + sum(rate(immich_gallery_queries_total_has_scores_false[5m]))) * 100",
          "legendFormat": "Score availability %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "Percentage",
          "min": 0,
          "max": 100
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "pointradius": 5,
      "legend": {
        "show": true,
        "values": true,
        "current": true,
        "alignAsTable": true
      }
    },
    {
      "id": 5,
      "title": "Upload Success Rate",
      "type": "singlestat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(immich_upload_events_total_success[5m])) / (sum(rate(immich_upload_events_total_success[5m])) + sum(rate(immich_upload_events_total_failure[5m]))) * 100",
          "refId": "A"
        }
      ],
      "format": "percent",
      "valueName": "current",
      "valueFontSize": "80%",
      "thresholds": "90,95",
      "colors": [
        "#d44a3a",
        "#e0b400",
        "#299c46"
      ],
      "colorBackground": false,
      "colorValue": true,
      "sparkline": {
        "show": true,
        "full": false,
        "lineColor": "rgb(31, 120, 193)",
        "fillColor": "rgba(31, 118, 189, 0.18)"
      }
    },
    {
      "id": 6,
      "title": "Total Uploads (5m)",
      "type": "singlestat",
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(immich_upload_events_total_success[5m])) + sum(increase(immich_upload_events_total_failure[5m]))",
          "refId": "A"
        }
      ],
      "format": "short",
      "valueName": "current",
      "valueFontSize": "80%",
      "colorBackground": false,
      "colorValue": false,
      "sparkline": {
        "show": true,
        "full": false,
        "lineColor": "rgb(31, 120, 193)",
        "fillColor": "rgba(31, 118, 189, 0.18)"
      }
    },
    {
      "id": 7,
      "title": "Avg Feature Service Latency (5m)",
      "type": "singlestat",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(immich_feature_service_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "refId": "A"
        }
      ],
      "format": "ms",
      "valueName": "current",
      "valueFontSize": "80%",
      "thresholds": "1000,5000",
      "colors": [
        "#299c46",
        "#e0b400",
        "#d44a3a"
      ],
      "colorBackground": false,
      "colorValue": true,
      "sparkline": {
        "show": true,
        "full": false,
        "lineColor": "rgb(31, 120, 193)",
        "fillColor": "rgba(31, 118, 189, 0.18)"
      }
    },
    {
      "id": 8,
      "title": "Gallery Queries (5m)",
      "type": "singlestat",
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(immich_gallery_queries_total_has_scores_true[5m])) + sum(increase(immich_gallery_queries_total_has_scores_false[5m]))",
          "refId": "A"
        }
      ],
      "format": "short",
      "valueName": "current",
      "valueFontSize": "80%",
      "colorBackground": false,
      "colorValue": false,
      "sparkline": {
        "show": true,
        "full": false,
        "lineColor": "rgb(31, 120, 193)",
        "fillColor": "rgba(31, 118, 189, 0.18)"
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
      "1d"
    ]
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "links": []
}

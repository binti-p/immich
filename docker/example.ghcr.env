# Example environment file for Aesthetic Hub with pre-built images
# Copy this file to .env and customize for your environment
#
# cp example.ghcr.env .env
# nano .env

# ============================================================================
# GitHub Container Registry
# ============================================================================

# Your GitHub organization or username (REQUIRED)
GITHUB_ORG=your-github-org

# Image tag to use (latest, main, or specific commit SHA)
IMAGE_TAG=latest

# ============================================================================
# Database Configuration
# ============================================================================

# Immich Postgres
DB_USERNAME=postgres
DB_PASSWORD=change-me-in-production
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=./postgres-data

# MLflow Postgres
MLFLOW_DB_USER=mlflow
MLFLOW_DB_PASSWORD=change-me-in-production
MLFLOW_DB_NAME=mlflowdb

# ============================================================================
# MinIO Configuration
# ============================================================================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production

# ============================================================================
# Immich Configuration
# ============================================================================

# Upload location (where Immich stores photos)
UPLOAD_LOCATION=./uploads

# Aesthetic service URL (internal)
AESTHETIC_SERVICE_URL=http://aesthetic-service:8000

# Enable aesthetic scoring
ENABLE_AESTHETIC_SCORING=true

# Logging
IMMICH_LOG_LEVEL=log
IMMICH_LOG_FORMAT=json

# ============================================================================
# Optional: Grafana
# ============================================================================

GRAFANA_PASSWORD=admin

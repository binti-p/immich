{
  "title": "Aesthetic Scoring Service",
  "uid": "aesthetic-scoring",
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "targets": [{
        "expr": "sum(rate(scoring_latency_seconds_count[5m])) by (environment)",
        "legendFormat": "{{environment}}"
      }]
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "targets": [{
        "expr": "sum(rate(scoring_errors_total[5m])) by (reason, environment)",
        "legendFormat": "{{environment}}/{{reason}}"
      }]
    },
    {
      "title": "P50 / P95 / P99 Latency (ms)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(scoring_latency_seconds_bucket{environment='production'}[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(scoring_latency_seconds_bucket{environment='production'}[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(scoring_latency_seconds_bucket{environment='production'}[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Alpha Distribution (Personalization Level)",
      "type": "heatmap",
      "targets": [{
        "expr": "sum(rate(scoring_alpha_bucket{environment='production'}[5m])) by (le)",
        "legendFormat": "{{le}}"
      }]
    },
    {
      "title": "Score Distribution",
      "type": "heatmap",
      "targets": [{
        "expr": "sum(rate(scoring_final_score_bucket{environment='production'}[5m])) by (le)",
        "legendFormat": "{{le}}"
      }]
    },
    {
      "title": "Low Confidence Rate",
      "type": "graph",
      "targets": [{
        "expr": "sum(rate(scoring_low_confidence_total{environment='production'}[5m])) / sum(rate(scoring_latency_seconds_count{environment='production'}[5m]))",
        "legendFormat": "low confidence %"
      }]
    }
  ]
}